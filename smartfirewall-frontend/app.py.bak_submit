@app.route("/users")
def users():
    return redirect("/settings")


@app.route("/groups")
@login_required
def groups():
    return render_template("groups.html", **template_context("groups"))


@app.route("/analytics/<int:group_id>")
@login_required
def content_analytics(group_id):
    return render_template("content_analytics.html", **template_context(None, group_id=group_id))


@app.route("/services")
@login_required
def services():
    return render_template("services.html", **template_context("services"))


@app.route("/backup")
@login_required
def backup():
